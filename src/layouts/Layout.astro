---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = 'Estate Sale Tales — True Stories from 20 Years of Estate Liquidation',
  description = 'Funny, bizarre, and heartwarming true stories from a career clearing out 1,000+ homes. Snakes, hidden treasures, awkward encounters, and everything in between.',
  ogImage = '/og-image.png',
  canonical,
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#a93232" />
    <meta name="author" content="Estate Sale Tales" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Estate Sale Tales" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Estate Sale Tales",
      "url": "https://estatesaletales.com",
      "description": "True stories from 20 years of estate liquidation"
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />

    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="container">
        <a href="/" class="nav-logo">
          <span class="nav-logo-title">Estate Sale Tales</span>
          <span class="nav-logo-author">by Susan Callicott</span>
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="navLinks">
          <li><a href="/stories" class={Astro.url.pathname.startsWith('/stories') ? 'active' : ''}>Stories</a></li>
          <li><a href="/guides" class={Astro.url.pathname.startsWith('/guides') ? 'active' : ''}>Guides</a></li>
          <li><a href="/about" class={Astro.url.pathname === '/about' || Astro.url.pathname === '/about/' ? 'active' : ''}>About</a></li>
          <li><a href="/newsletter" class={Astro.url.pathname === '/newsletter' || Astro.url.pathname === '/newsletter/' ? 'active' : ''}>Newsletter</a></li>
          <li><a href="/book" class={`nav-cta ${Astro.url.pathname === '/book' || Astro.url.pathname === '/book/' ? 'nav-cta-active' : ''}`}>Get the Book</a></li>
        </ul>
      </div>
    </nav>

    <slot />

    <!-- Sticky Newsletter Bar -->
    <div class="sticky-newsletter" id="stickyNewsletter" style="display:none">
      <div class="container sticky-newsletter-inner">
        <p class="sticky-newsletter-text"><strong>Get a new estate sale story every week.</strong> Free in your inbox.</p>
        <form class="sticky-newsletter-form" action="#" method="post">
          <input type="email" name="email" placeholder="Your email" required />
          <button type="submit">Subscribe</button>
        </form>
        <button class="sticky-newsletter-close" id="closeNewsletter" aria-label="Close newsletter bar">&times;</button>
      </div>
    </div>

    <script>
      // Show after scrolling 40% of the page, hide if dismissed
      const bar = document.getElementById('stickyNewsletter');
      const closeBtn = document.getElementById('closeNewsletter');
      let dismissed = sessionStorage.getItem('newsletter_dismissed');

      if (!dismissed && bar) {
        window.addEventListener('scroll', function showBar() {
          if (window.scrollY > document.body.scrollHeight * 0.3) {
            bar.style.display = '';
            requestAnimationFrame(() => bar.classList.add('visible'));
            window.removeEventListener('scroll', showBar);
          }
        });
      }

      if (closeBtn && bar) {
        closeBtn.addEventListener('click', () => {
          bar.classList.remove('visible');
          bar.classList.add('hidden');
          sessionStorage.setItem('newsletter_dismissed', '1');
        });
      }
    </script>

    <script>
      const toggle = document.getElementById('navToggle');
      const links = document.getElementById('navLinks');
      if (toggle && links) {
        toggle.addEventListener('click', () => {
          links.classList.toggle('open');
          toggle.classList.toggle('open');
        });
      }
    </script>

    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a href="/" class="footer-logo">Estate Sale Tales<span class="footer-byline">by Susan Callicott</span></a>
            <p class="footer-tagline">True stories from 20 years of estate liquidation.</p>
          </div>
          <div class="footer-links-group">
            <h4>Read</h4>
            <ul>
              <li><a href="/stories">Stories</a></li>
              <li><a href="/guides">Guides</a></li>
              <li><a href="/newsletter">Newsletter</a></li>
            </ul>
          </div>
          <div class="footer-links-group">
            <h4>More</h4>
            <ul>
              <li><a href="/book">The Book</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/press">Press</a></li>
              <li><a href="https://www.facebook.com/EstateSaleTales" target="_blank" rel="noopener noreferrer">Facebook</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2026 Estate Sale Tales. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Reset */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

  :root {
    --bg: #faf7f2;
    --bg-warm: #f3ede4;
    --bg-card: #ffffff;
    --bg-accent: #f5efe6;
    --text: #2c2420;
    --text-secondary: #5e524a;
    --text-muted: #8a7e76;
    --accent: #a93232;
    --accent-hover: #8f2a2a;
    --accent-light: rgba(169, 50, 50, 0.08);
    --border: #e0d6cc;
    --border-light: #ece5dc;
    --font-serif: 'Lora', Georgia, 'Times New Roman', serif;
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --container-max: 1100px;
    --radius: 8px;
    --radius-lg: 16px;
    --shadow-sm: 0 1px 3px rgba(44, 36, 32, 0.06);
    --shadow-md: 0 4px 12px rgba(44, 36, 32, 0.08);
    --shadow-lg: 0 8px 30px rgba(44, 36, 32, 0.1);
    --transition: 200ms ease;
  }

  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
  }

  a { color: var(--accent); text-decoration: none; transition: color var(--transition); }
  a:hover { color: var(--accent-hover); }
  img { max-width: 100%; display: block; }

  .container { max-width: var(--container-max); margin: 0 auto; padding: 0 1.5rem; }

  /* Top accent bar */
  body::before {
    content: ''; display: block; height: 3px;
    background: linear-gradient(90deg, var(--accent) 0%, #d4785a 50%, var(--accent) 100%);
    position: sticky; top: 0; z-index: 101;
  }

  /* Nav */
  .nav {
    position: sticky; top: 3px; z-index: 100;
    padding: 0.85rem 0;
    background: rgba(250, 247, 242, 0.95);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-light);
  }
  .nav .container { display: flex; align-items: center; justify-content: space-between; }
  .nav-logo {
    display: flex; flex-direction: column; text-decoration: none; line-height: 1;
  }
  .nav-logo:hover .nav-logo-title { color: var(--accent); }
  .nav-logo-title {
    font-family: var(--font-serif); font-size: 1.25rem; font-weight: 700;
    color: var(--text); letter-spacing: -0.01em;
    transition: color var(--transition);
  }
  .nav-logo-author {
    font-family: var(--font-serif); font-size: 0.7rem; font-weight: 400;
    color: var(--text-muted); font-style: italic;
    margin-top: 0.1rem;
  }
  .nav-links { display: flex; gap: 1.75rem; list-style: none; align-items: center; }
  .nav-links a {
    color: var(--text-secondary); font-size: 0.9rem; font-weight: 500;
    transition: color var(--transition);
  }
  .nav-links a:hover { color: var(--text); }
  .nav-cta {
    background: var(--accent) !important; color: white !important;
    padding: 0.5rem 1.25rem; border-radius: var(--radius); font-weight: 600 !important;
  }
  .nav-cta:hover { background: var(--accent-hover) !important; }
  .nav-links a.active { color: var(--text); font-weight: 600; }
  .nav-toggle {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 4px; padding: 4px;
  }
  .nav-toggle span {
    display: block; width: 22px; height: 2px; background: var(--text);
    transition: all 0.2s ease; border-radius: 1px;
  }
  .nav-toggle.open span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }
  @media (max-width: 640px) {
    .nav-toggle { display: flex; }
    .nav-links {
      display: none; position: absolute; top: 100%; left: 0; right: 0;
      flex-direction: column; gap: 0; padding: 0.75rem 1.5rem 1rem;
      background: rgba(250, 247, 242, 0.98); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-light);
    }
    .nav-links.open { display: flex; }
    .nav-links li { padding: 0.5rem 0; }
    .nav-links a { font-size: 0.95rem; }
    .nav-cta { text-align: center; margin-top: 0.5rem; }
  }

  /* Section helpers */
  .section { padding: 5rem 0; }
  .section-label {
    display: inline-block; font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--accent); margin-bottom: 0.75rem;
  }
  .section-title {
    font-family: var(--font-serif); font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700; line-height: 1.2; margin-bottom: 1rem; color: var(--text);
  }
  .section-title::after {
    content: ''; display: block; width: 50px; height: 3px;
    background: var(--accent); margin-top: 0.75rem; border-radius: 2px;
  }
  .text-center { text-align: center; }
  .text-center .section-title::after { margin-left: auto; margin-right: auto; }
  .section-subtitle {
    font-size: 1.1rem; color: var(--text-secondary); max-width: 600px; line-height: 1.7;
    margin-top: 0.5rem;
  }

  /* Cards */
  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
  .card {
    display: block; padding: 1.75rem; background: var(--bg-card);
    border: 1px solid var(--border-light); border-radius: var(--radius-lg);
    border-left: 3px solid transparent;
    text-decoration: none; transition: all var(--transition);
  }
  .card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); border-color: var(--border); border-left-color: var(--accent); }
  .card-category {
    display: inline-block; font-size: 0.72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--accent); margin-bottom: 0.75rem;
  }
  .card-title {
    font-family: var(--font-serif); font-size: 1.2rem; font-weight: 600;
    color: var(--text); line-height: 1.3; margin-bottom: 0.5rem;
  }
  .card-excerpt { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
  .card-meta { display: flex; gap: 0.5rem; font-size: 0.8rem; color: var(--text-muted); }
  .card-badge {
    display: inline-block; font-size: 0.68rem; font-weight: 600;
    background: var(--accent-light); color: var(--accent);
    padding: 0.2rem 0.6rem; border-radius: 100px; margin-left: 0.5rem;
  }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.8rem 1.8rem; border-radius: var(--radius); font-size: 1rem;
    font-weight: 600; text-decoration: none; transition: all var(--transition); border: none; cursor: pointer;
  }
  .btn-primary { background: var(--accent); color: white; box-shadow: 0 2px 8px rgba(169, 50, 50, 0.25); }
  .btn-primary:hover { background: var(--accent-hover); color: white; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(169, 50, 50, 0.3); }
  .btn-secondary { background: transparent; color: var(--accent); border: 2px solid var(--accent); }
  .btn-secondary:hover { background: var(--accent-light); }

  /* Prose (story/guide content) */
  .prose { max-width: 680px; margin: 0 auto; font-family: var(--font-serif); font-size: 1.1rem; line-height: 1.9; color: var(--text); }
  .prose h2 { font-size: 1.5rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 0.75rem; font-family: var(--font-serif); }
  .prose h3 { font-size: 1.2rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.5rem; font-family: var(--font-sans); }
  .prose p { margin-bottom: 1.25rem; }
  .prose strong { font-weight: 600; }
  .prose ul, .prose ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
  .prose li { margin-bottom: 0.4rem; }
  .prose blockquote {
    border-left: 3px solid var(--accent); padding-left: 1.25rem;
    margin: 1.5rem 0; font-style: italic; color: var(--text-secondary);
  }
  .prose a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .prose code { background: var(--bg-warm); padding: 0.15em 0.4em; border-radius: 4px; font-size: 0.9em; }
  .prose table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-family: var(--font-sans); font-size: 0.9rem; }
  .prose th { text-align: left; padding: 0.75rem; background: var(--bg-warm); font-weight: 600; border-bottom: 2px solid var(--border); }
  .prose td { padding: 0.75rem; border-bottom: 1px solid var(--border-light); }
  .prose hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

  /* Article header */
  .article-header { max-width: 680px; margin: 0 auto 2.5rem; }
  .article-back { display: inline-block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem; }
  .article-back:hover { color: var(--accent); }
  .article-title {
    font-family: var(--font-serif); font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700; line-height: 1.2; margin-top: 0.5rem; margin-bottom: 0.75rem;
  }
  .article-meta { display: flex; gap: 0.5rem; font-size: 0.85rem; color: var(--text-muted); flex-wrap: wrap; }
  .article-contributor { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.5rem; font-style: italic; }

  /* Book CTA box */
  .book-cta {
    max-width: 680px; margin: 3rem auto; padding: 2rem 2.5rem;
    background: linear-gradient(135deg, var(--bg-accent) 0%, #faf5ee 100%);
    border: 1px solid var(--border); border-left: 4px solid var(--accent);
    border-radius: var(--radius-lg); text-align: center;
  }
  .book-cta p { font-family: var(--font-serif); font-size: 1.05rem; color: var(--text-secondary); margin-bottom: 1rem; }
  .book-cta .btn { margin-top: 0.5rem; }

  /* Related articles */
  .related { max-width: 680px; margin: 3rem auto 0; padding-top: 2.5rem; border-top: 1px solid var(--border-light); }
  .related-title { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 600; margin-bottom: 1.25rem; }

  /* Newsletter box */
  .newsletter-box {
    background: linear-gradient(135deg, var(--bg-warm) 0%, #f0e8dc 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 3rem; text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .newsletter-box h3 { font-family: var(--font-serif); font-size: 1.4rem; margin-bottom: 0.5rem; }
  .newsletter-box p { color: var(--text-secondary); margin-bottom: 1.25rem; }
  .newsletter-form { display: flex; gap: 0.5rem; max-width: 400px; margin: 0 auto; }
  .newsletter-form input {
    flex: 1; padding: 0.75rem 1rem; border: 1px solid var(--border);
    border-radius: var(--radius); font-size: 0.9rem; background: var(--bg-card);
  }
  .newsletter-form button {
    padding: 0.75rem 1.5rem; background: var(--accent); color: white;
    border: none; border-radius: var(--radius); font-weight: 600; cursor: pointer;
    transition: background var(--transition);
  }
  .newsletter-form button:hover { background: var(--accent-hover); }

  /* Footer */
  .footer { padding: 4rem 0 2rem; background: var(--bg-warm); border-top: 1px solid var(--border); }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; margin-bottom: 2rem; }
  .footer-logo { font-family: var(--font-serif); font-size: 1.1rem; font-weight: 700; color: var(--text); display: block; line-height: 1.2; }
  .footer-byline { display: block; font-size: 0.75rem; font-weight: 400; color: var(--text-muted); font-style: italic; margin-top: 0.15rem; }
  .footer-tagline { color: var(--text-muted); font-size: 0.9rem; margin-top: 0.5rem; }
  .footer-links-group h4 { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.75rem; }
  .footer-links-group ul { list-style: none; }
  .footer-links-group li { margin-bottom: 0.4rem; }
  .footer-links-group a { color: var(--text-secondary); font-size: 0.9rem; }
  .footer-links-group a:hover { color: var(--accent); }
  .footer-bottom { padding-top: 1.5rem; border-top: 1px solid var(--border); text-align: center; }
  .footer-bottom p { color: var(--text-muted); font-size: 0.8rem; }

  /* Sticky Newsletter Bar */
  .sticky-newsletter {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
    background: var(--accent); color: white;
    padding: 0.85rem 0;
    transform: translateY(100%);
    transition: transform 0.4s ease;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.15);
  }
  .sticky-newsletter.visible { transform: translateY(0); }
  .sticky-newsletter.hidden { transform: translateY(100%); }
  .sticky-newsletter-inner {
    display: flex; align-items: center; gap: 1.25rem; justify-content: center; flex-wrap: wrap;
  }
  .sticky-newsletter-text {
    font-size: 0.9rem; color: white; margin: 0;
  }
  .sticky-newsletter-text strong { font-weight: 700; }
  .sticky-newsletter-form {
    display: flex; gap: 0.4rem;
  }
  .sticky-newsletter-form input {
    padding: 0.5rem 0.85rem; border: none; border-radius: var(--radius);
    font-size: 0.85rem; width: 200px; background: rgba(255,255,255,0.95); color: var(--text);
  }
  .sticky-newsletter-form input::placeholder { color: var(--text-muted); }
  .sticky-newsletter-form button {
    padding: 0.5rem 1rem; background: white; color: var(--accent);
    border: none; border-radius: var(--radius); font-weight: 700;
    font-size: 0.85rem; cursor: pointer; transition: background var(--transition);
  }
  .sticky-newsletter-form button:hover { background: rgba(255,255,255,0.9); }
  .sticky-newsletter-close {
    background: none; border: none; color: rgba(255,255,255,0.7);
    font-size: 1.4rem; cursor: pointer; padding: 0 0.25rem; line-height: 1;
    transition: color var(--transition);
  }
  .sticky-newsletter-close:hover { color: white; }

  @media (max-width: 768px) {
    .section { padding: 3.5rem 0; }
    .card-grid { grid-template-columns: 1fr; }
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .newsletter-form { flex-direction: column; }
    .sticky-newsletter-inner { flex-direction: column; text-align: center; gap: 0.75rem; }
    .sticky-newsletter-form input { width: 160px; }
    .sticky-newsletter-close { position: absolute; top: 0.5rem; right: 1rem; }
    .sticky-newsletter { padding: 1rem 0; position: relative; }
  }
</style>
