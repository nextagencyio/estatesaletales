---
import Layout from '../layouts/Layout.astro';

const amazonUrl = 'https://www.amazon.com/Estate-Sale-Tales-Susan-Callicott-ebook/dp/B0D2DPC1Y1/';
---

<Layout
  title="Press Kit — Estate Sale Tales"
  description="Media resources for Estate Sale Tales. Author bio, book information, high-res images, and contact details for press inquiries."
>
  <section class="section">
    <div class="container content-section">
      <p class="section-label">Press</p>
      <h1 class="section-title">Press Kit</h1>
      <p class="section-subtitle">
        Everything you need for coverage of <em>Estate Sale Tales</em>. For questions or interview requests, reach out directly.
      </p>
    </div>
  </section>

  <!-- Book + Key Facts side by side -->
  <section class="section" style="background: var(--bg-warm);">
    <div class="container content-section">
      <div class="book-facts-grid">
        <div class="book-cover-col">
          <img src="/book-cover.jpg" alt="Estate Sale Tales book cover" class="press-cover" />
          <p class="download-link">
            <a href="/book-cover.jpg" download>Download high-res cover</a>
          </p>
        </div>
        <div class="facts-col">
          <h2>Key Facts</h2>
          <ul class="facts-list">
            <li><strong>Title:</strong> Estate Sale Tales</li>
            <li><strong>Author:</strong> Susan Callicott</li>
            <li><strong>Genre:</strong> Humor / Nonfiction / Memoir</li>
            <li><strong>Stories:</strong> 50+</li>
            <li><strong>Rating:</strong> 4.8 out of 5 stars on Amazon</li>
            <li><strong>Formats:</strong> Paperback, Kindle ebook</li>
            <li><strong>Amazon:</strong> <a href={amazonUrl} target="_blank" rel="noopener">View on Amazon</a></li>
            <li><strong>Website:</strong> <a href="https://estatesaletales.com">estatesaletales.com</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- About the Book -->
  <section class="section">
    <div class="container content-section">
      <div class="press-block">
        <h2>About the Book</h2>
        <p>
          <em>Estate Sale Tales</em> is a collection of true stories from more than 20 years of estate liquidation. Spanning over 50 stories, the book captures the funny, bizarre, heartwarming, and downright unbelievable moments that come from clearing out 1,000+ homes. From snakes under beds to hidden fortunes in coat pockets, these are the stories that estate sale professionals swap after hours — now collected for the first time.
        </p>
      </div>
    </div>
  </section>

  <!-- Author Bio + Photo -->
  <section class="section" style="background: var(--bg-warm);">
    <div class="container content-section">
      <div class="press-block">
        <h2>Author Bio</h2>
        <div class="author-grid">
          <div class="author-photo-col">
            <img src="/author-photo.jpg" alt="Susan Callicott, author of Estate Sale Tales" class="press-author-photo" />
            <p class="download-link">
              <a href="/author-photo.jpg" download>Download author photo</a>
            </p>
          </div>
          <div class="author-bio-col">
            <p>
              Susan Callicott is the founder of Lucy & Ethel Estate Sales in the Dallas/Fort Worth, Texas area. She has spent over two decades in the estate liquidation industry, personally overseeing the clearing of more than 1,000 homes. What started as a practical career became an unexpected window into the lives, habits, and hidden stories of everyday people. <em>Estate Sale Tales</em> is her first book, with contributions from fellow professionals across the estate sale, auction, and cleanout industries.
            </p>
            <div class="bio-note">
              <strong>Short bio for print:</strong> Susan Callicott, founder of Lucy & Ethel Estate Sales in Dallas/Fort Worth, has cleared out over 1,000 homes in a 20-year career. <em>Estate Sale Tales</em> collects the true stories — funny, strange, and human — from that experience.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Story Angles -->
  <section class="section">
    <div class="container content-section">
      <div class="press-block">
        <h2>Story Angles & Interview Topics</h2>
        <p>Ready-made hooks for features, podcasts, and interviews:</p>
        <div class="angles-grid">
          <div class="angle-card">
            <h3>The Wildest Things Found in Homes</h3>
            <p>Snakes, raccoons, hidden cash, and collections that defy explanation — what estate sale pros find behind closed doors.</p>
          </div>
          <div class="angle-card">
            <h3>What Our Stuff Says About Us</h3>
            <p>Estate sales offer an intimate look at how people live. Susan reflects on the humanity behind the belongings.</p>
          </div>
          <div class="angle-card">
            <h3>The Rise of Estate Sale Culture</h3>
            <p>From niche industry to mainstream hobby — how estate sales became a treasure-hunting phenomenon.</p>
          </div>
          <div class="angle-card">
            <h3>Women in Estate Liquidation</h3>
            <p>Susan built a 20-year business in a physically demanding field. The challenges, rewards, and lessons learned.</p>
          </div>
          <div class="angle-card">
            <h3>Hoarder Houses & Hidden Treasures</h3>
            <p>Navigating floor-to-ceiling collections — and the surprising valuables buried underneath.</p>
          </div>
          <div class="angle-card">
            <h3>From Career to Book</h3>
            <p>After two decades of friends saying "you should write a book," Susan finally did. The journey from stories told at dinner parties to published author.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pull Quotes -->
  <section class="section" style="background: var(--bg-warm);">
    <div class="container content-section">
      <div class="press-block">
        <h2>Ready-to-Use Quotes</h2>
        <p>From verified Amazon reviews — available for use in coverage:</p>
        <div class="quotes-list">
          <blockquote class="pull-quote">
            <p>"One of the funniest books I've ever read. Crazy, clean, and good stories that leave you laughing and marveling at human nature."</p>
            <cite>— Richard B., Amazon Verified Purchase</cite>
          </blockquote>
          <blockquote class="pull-quote">
            <p>"I was giggling and chuckling the whole flight!! People may have looked at me weird but I didn't care."</p>
            <cite>— Saruhh, Amazon Verified Purchase</cite>
          </blockquote>
          <blockquote class="pull-quote">
            <p>"Being an estate liquidator in Fort Worth, I was grinning, nodding, and laughing page by page. I read it in 2 nights."</p>
            <cite>— Georgann P Muckleroy, Amazon Verified Purchase</cite>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section">
    <div class="container content-section text-center">
      <h2 class="section-title">Get in Touch</h2>
      <p class="section-subtitle" style="margin: 0 auto 1.5rem;">
        For press inquiries, interview requests, or review copies:
      </p>
      <a href="mailto:estatesaletales@gmail.com" class="btn btn-secondary">estatesaletales@gmail.com</a>
    </div>
  </section>
</Layout>

<style>
  .content-section {
    max-width: 720px;
  }
  .section-subtitle {
    margin-bottom: 1rem;
  }
  .press-block h2 {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--text);
  }
  .press-block p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }

  /* Book + Facts grid */
  .book-facts-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .press-cover {
    width: 220px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }
  .download-link {
    font-size: 0.82rem;
    margin-top: 0.5rem;
  }
  .download-link a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .facts-col h2 {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .facts-list {
    list-style: none;
    padding: 0;
  }
  .facts-list li {
    padding: 0.5rem 0;
    font-size: 0.95rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
  }
  .facts-list li:last-child {
    border-bottom: none;
  }
  .facts-list li strong {
    color: var(--text);
  }
  .facts-list a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Author grid */
  .author-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    align-items: start;
  }
  .press-author-photo {
    width: 160px;
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(44,36,32,0.12);
  }
  .bio-note {
    font-size: 0.9rem;
    font-style: italic;
    background: var(--bg);
    padding: 1rem;
    border-radius: var(--radius);
    margin-top: 0.5rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .bio-note strong {
    font-style: normal;
    color: var(--text);
  }

  /* Story angles */
  .angles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }
  .angle-card {
    background: var(--bg-warm);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }
  .angle-card h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.4rem;
  }
  .angle-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Pull quotes */
  .quotes-list {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .pull-quote {
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
  }
  .pull-quote p {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--text);
    line-height: 1.75;
    margin-bottom: 0.4rem;
  }
  .pull-quote cite {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-style: normal;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .book-facts-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .press-cover { width: 180px; margin: 0 auto; }
    .book-cover-col .download-link { text-align: center; }
    .facts-list { text-align: left; }
    .author-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .press-author-photo { width: 140px; margin: 0 auto; }
    .author-photo-col .download-link { text-align: center; }
    .author-bio-col { text-align: left; }
    .angles-grid { grid-template-columns: 1fr; }
  }
</style>
