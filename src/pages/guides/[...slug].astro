---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);

const amazonUrl = 'https://www.amazon.com/Estate-Sale-Tales-Susan-Callicott-ebook/dp/B0D2DPC1Y1/';

// Related guides: other guides, sorted by date, max 3
const allGuides = await getCollection('guides');
const relatedGuides = allGuides
  .filter((g) => g.id !== guide.id)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": guide.data.title,
  "description": guide.data.excerpt,
  "datePublished": guide.data.date,
  "author": {
    "@type": "Person",
    "name": "Susan Callicott"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Estate Sale Tales",
    "url": "https://estatesaletales.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://estatesaletales.com/guides/${guide.id}`
  }
};

// FAQ schema for the "What Is an Estate Sale?" guide
const faqSchema = guide.id === 'what-is-an-estate-sale' ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Does 'estate sale' mean someone died?", "acceptedAnswer": { "@type": "Answer", "text": "Not necessarily. While many estate sales do happen after a death, they also occur during downsizing, divorce, relocation, or any situation where someone needs to liquidate most or all of their household belongings." }},
    { "@type": "Question", "name": "How is an estate sale different from an auction?", "acceptedAnswer": { "@type": "Answer", "text": "At an estate sale, everything has a set price and buyers purchase items directly — like shopping in a store. At an auction, items are sold to the highest bidder." }},
    { "@type": "Question", "name": "Can anyone go to an estate sale?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Estate sales are open to the public. You don't need an invitation or any special credentials. Just show up, browse, and buy what you like." }},
    { "@type": "Question", "name": "How do I find estate sales near me?", "acceptedAnswer": { "@type": "Answer", "text": "The best resources are EstateSales.net and EstateSales.org. Most estate sale companies also maintain email lists and post on social media." }},
    { "@type": "Question", "name": "Are estate sale prices negotiable?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on the day. Most companies hold firm on prices the first day, then offer progressive discounts on subsequent days — often 25% off on day two and 50% off on the final day." }},
    { "@type": "Question", "name": "How do estate sale companies get paid?", "acceptedAnswer": { "@type": "Answer", "text": "Most companies work on commission — typically 25% to 50% of total sales. The company handles everything and the client receives a check for their share after the sale." }},
    { "@type": "Question", "name": "How long does an estate sale last?", "acceptedAnswer": { "@type": "Answer", "text": "Most estate sales run two to three days, typically Thursday through Saturday or Friday through Sunday. Setup usually takes three to five days before the sale." }},
    { "@type": "Question", "name": "What should I bring to an estate sale?", "acceptedAnswer": { "@type": "Answer", "text": "Cash is king, though most companies now accept credit cards. Bring your own bags or boxes, wear comfortable shoes, and bring patience." }},
    { "@type": "Question", "name": "Can I sell my own stuff at an estate sale?", "acceptedAnswer": { "@type": "Answer", "text": "You can run your own estate sale, but most people underestimate the work involved. Professional companies have the experience, customer base, and pricing knowledge to consistently get better results." }},
  ]
} : null;
---

<Layout
  title={`${guide.data.title} — Estate Sale Tales`}
  description={guide.data.excerpt}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <section class="section">
    <div class="container">
      <div class="article-header">
        <a href="/guides" class="article-back">&larr; All Guides</a>
        <h1 class="article-title">{guide.data.title}</h1>
        <div class="article-meta">
          <span>{guide.data.readTime}</span>
          <span>&middot;</span>
          <span>{guide.data.date}</span>
        </div>
      </div>

      <div class="prose">
        <Content />
      </div>

      <div class="share-buttons">
        <span class="share-label">Share this guide:</span>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=https://estatesaletales.com/guides/${guide.id}`} target="_blank" rel="noopener" class="share-btn">Facebook</a>
        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(guide.data.title)}&url=https://estatesaletales.com/guides/${guide.id}`} target="_blank" rel="noopener" class="share-btn">Twitter</a>
        <a href={`mailto:?subject=${encodeURIComponent(guide.data.title)}&body=Check out this estate sale guide: https://estatesaletales.com/guides/${guide.id}`} class="share-btn">Email</a>
      </div>

      <div class="book-cta">
        <p>Want the stories behind the advice? Estate Sale Tales has 50+ true stories from the field.</p>
        <a href={amazonUrl} class="btn btn-primary" target="_blank" rel="noopener">Buy on Amazon</a>
      </div>

      {relatedGuides.length > 0 && (
        <div class="related">
          <h2 class="related-title">More Guides</h2>
          <div class="card-grid">
            {relatedGuides.map((related) => (
              <a href={`/guides/${related.id}`} class="card">
                <h3 class="card-title">{related.data.title}</h3>
                <p class="card-excerpt">{related.data.excerpt}</p>
                <div class="card-meta">
                  <span>{related.data.readTime}</span>
                  <span>&middot;</span>
                  <span>{related.data.date}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .share-buttons { max-width: 680px; margin: 2rem auto; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .share-label { font-size: 0.85rem; color: var(--text-muted); font-weight: 500; }
  .share-btn { font-size: 0.8rem; padding: 0.4rem 0.85rem; border: 1px solid var(--border); border-radius: var(--radius); color: var(--text-secondary); transition: all 0.2s; }
  .share-btn:hover { border-color: var(--accent); color: var(--accent); }
</style>
