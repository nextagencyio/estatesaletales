---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allStories = await getCollection('stories');

// Hand-pick the most compelling stories for the homepage
const featuredSlugs = [
  'here-kitty-kitty-kitty',
  'adventure-in-little-forest-hills',
  'the-weedy-guys',
  'snake-under-the-bed',
  'at-the-salon',
  'he-stood-his-ground',
];
const featuredStories = featuredSlugs
  .map(slug => allStories.find(s => s.id === slug))
  .filter(Boolean)
  .slice(0, 6);
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <p class="section-label">From the world of estate liquidation</p>
        <h1 class="hero-title">True Stories from 20 Years of Estate Liquidation</h1>
        <p class="hero-subtitle">
          After clearing out 1,000+ homes, you see things. A snake under the bed. A goose blocking traffic. A naked man in the kitchen. These are the stories we couldn't make up.
        </p>
        <div class="hero-actions">
          <a href="https://www.amazon.com/Estate-Sale-Tales-Susan-Callicott-ebook/dp/B0D2DPC1Y1/" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Get the Book</a>
          <a href="/stories" class="btn btn-secondary">Read Stories Free</a>
        </div>
        <p class="hero-rating">&#9733;&#9733;&#9733;&#9733;&#9733; 4.8 stars on Amazon</p>
      </div>
      <div class="hero-book">
        <img src="/book-cover.jpg" alt="Estate Sale Tales by Susan Callicott — book cover" class="hero-book-img" />
      </div>
    </div>
  </section>

  <!-- Featured Stories -->
  <section class="section">
    <div class="container">
      <p class="section-label">Sample Stories</p>
      <h2 class="section-title">Fresh from the Field</h2>
      <p class="section-subtitle">A taste of the tales. Real encounters from real estate sales — you can't make this stuff up.</p>
      <div class="card-grid" style="margin-top: 2rem;">
        {featuredStories.map((story) => (
          <a href={`/stories/${story.id}`} class="card">
            <span class="card-category">
              {story.data.category}
              {story.data.inBook && <span class="card-badge">From the Book</span>}
            </span>
            <h3 class="card-title">{story.data.title}</h3>
            <p class="card-excerpt">{story.data.excerpt}</p>
            <div class="card-meta">
              <span>{story.data.readTime}</span>
              <span>&middot;</span>
              <span>{story.data.date}</span>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/stories" class="btn btn-secondary">View All Stories</a>
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="section" style="background: var(--bg-warm);">
    <div class="container about-teaser">
      <p class="section-label">About the Author</p>
      <h2 class="section-title">20 Years. 1,000+ Homes. Countless Stories.</h2>
      <div class="about-grid">
        <img src="/author-photo.jpg" alt="Susan Callicott" class="about-photo" />
        <div>
          <p class="section-subtitle">
            Susan Callicott, founder of Lucy & Ethel Estate Sales in the Dallas/Fort Worth area, has spent over two decades clearing out homes and collecting the wildest stories along the way. What started as a career became a front-row seat to the strangest, funniest, and most human moments imaginable.
          </p>
          <a href="/about" class="btn btn-secondary" style="margin-top: 1rem;">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Amazon Reviews -->
  <section class="section">
    <div class="container text-center">
      <p class="section-label">Amazon Reviews</p>
      <h2 class="section-title">4.8 Stars on Amazon (8 reviews)</h2>
      <div class="testimonial-grid">
        <blockquote class="testimonial">
          <span class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <p>"I was giggling and chuckling the whole flight!! People may have looked at me weird but I didn't care."</p>
          <cite>— Saruhh, Verified Purchase</cite>
        </blockquote>
        <blockquote class="testimonial">
          <span class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <p>"One of the funniest books I've ever read. Crazy, clean, and good stories that leave you laughing and marveling at human nature."</p>
          <cite>— Richard B., Verified Purchase</cite>
        </blockquote>
        <blockquote class="testimonial">
          <span class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <p>"Being an estate liquidator in Fort Worth, I was grinning, nodding, and laughing page by page. I read it in 2 nights."</p>
          <cite>— Georgann P Muckleroy, Verified Purchase</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Industry Endorsements -->
  <section class="section" style="background: var(--bg-warm);">
    <div class="container text-center">
      <p class="section-label">Industry Endorsements</p>
      <h2 class="section-title">Loved by Estate Sale Pros</h2>
      <div class="testimonial-grid">
        <blockquote class="testimonial">
          <p>"Susan's 'Tales' are the real deal. A must-read that will keep you laughing long after the lights go out!"</p>
          <cite>— Terry Lee &amp; Fred, 24-7 Estate Sales</cite>
        </blockquote>
        <blockquote class="testimonial">
          <p>"True events that will leave you either laughing or in total amazement!"</p>
          <cite>— CAGA Certified Appraisers, Dallas, Texas</cite>
        </blockquote>
        <blockquote class="testimonial">
          <p>"An amazingly courageous woman tells her gripping story...gritty, fast-paced, steamy and satisfying."</p>
          <cite>— Dee Blakey, RESELL IT! Dallas, Texas</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Book CTA -->
  <section class="section book-cta-section">
    <div class="container text-center">
      <p class="section-label">The Book</p>
      <h2 class="section-title">These Stories (and 50 More) Are in the Book</h2>
      <p class="section-subtitle" style="margin: 0.5rem auto 2rem;">
        <em>Estate Sale Tales</em> collects the best stories from two decades of clearing out homes — the funny, the bizarre, the heartwarming, and the ones that still keep us up at night.
      </p>
      <a href="/book" class="btn btn-primary">Get the Book on Amazon</a>
      <div style="margin-top: 2.5rem;">
        <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.75rem;">Or get a free story every week:</p>
        <form class="newsletter-form" action="#" method="post" style="justify-content: center;">
          <input type="email" name="email" placeholder="Your email address" required />
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(135deg, var(--bg-accent) 0%, var(--bg) 100%);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }
  .hero-content {
    max-width: 580px;
  }
  .hero-content > * {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.6s ease forwards;
  }
  .hero-content > *:nth-child(1) { animation-delay: 0.1s; }
  .hero-content > *:nth-child(2) { animation-delay: 0.2s; }
  .hero-content > *:nth-child(3) { animation-delay: 0.35s; }
  .hero-content > *:nth-child(4) { animation-delay: 0.5s; }
  .hero-content > *:nth-child(5) { animation-delay: 0.65s; }
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    color: var(--text);
  }
  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.75;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .hero-rating {
    margin-top: 1.25rem;
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 600;
    animation: fadeUp 0.6s ease 0.8s forwards;
    opacity: 0;
    transform: translateY(16px);
  }
  .hero-book {
    flex-shrink: 0;
    opacity: 0;
    animation: fadeIn 0.8s ease 0.3s forwards;
  }
  @keyframes fadeIn {
    to { opacity: 1; }
  }
  .hero-book-img {
    width: 280px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg), 0 20px 60px rgba(42, 51, 40, 0.15);
    transform: rotate(2deg);
    transition: transform 0.4s ease;
    animation: float 6s ease-in-out infinite;
  }
  .hero-book-img:hover {
    transform: rotate(0deg) scale(1.03);
    animation-play-state: paused;
  }
  @keyframes float {
    0%, 100% { transform: rotate(2deg) translateY(0); }
    50% { transform: rotate(2deg) translateY(-10px); }
  }
  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }
    .hero-content { max-width: 100%; }
    .hero-actions { justify-content: center; }
    .hero-book { order: -1; }
    .hero-book-img { width: 200px; margin: 0 auto; }
  }
  .about-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 12px rgba(44,36,32,0.1);
  }
  .about-teaser {
    max-width: 720px;
  }
  .about-grid {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    margin-top: 1.5rem;
  }
  .about-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(44,36,32,0.1);
  }
  @media (max-width: 640px) {
    .about-grid { flex-direction: column; align-items: center; text-align: center; }
  }
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .testimonial {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    position: relative;
  }
  .testimonial::before {
    content: '\201C';
    position: absolute;
    top: 0.75rem;
    right: 1.25rem;
    font-family: var(--font-serif);
    font-size: 3rem;
    line-height: 1;
    color: var(--accent-light);
    opacity: 0.6;
  }
  .review-stars {
    display: block;
    color: #e8a838;
    font-size: 1.1rem;
    letter-spacing: 2px;
    margin-bottom: 0.75rem;
  }
  .testimonial p {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text);
    font-style: italic;
    margin-bottom: 0.75rem;
  }
  .testimonial cite {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: normal;
    font-weight: 500;
  }
  .book-cta-section {
    background: var(--bg-card);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }
</style>
